{
  "name": "banking-search",
  "version": "1.0.0",
  "description": "Smart Search Web Component for banking applications — built with Lit",
  "type": "module",
  "main": "dist/banking-search.umd.js",
  "module": "dist/banking-search.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/banking-search.js",
      "require": "./dist/banking-search.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite demo",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:browser": "web-test-runner tests/browser/**/*.test.ts --node-resolve",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "web-component",
    "custom-element",
    "banking",
    "search",
    "lit"
  ],
  "license": "MIT",
  "dependencies": {
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "@web/dev-server-esbuild": "^1.0.2",
    "@web/test-runner": "^0.19.0",
    "@web/test-runner-playwright": "^0.11.0",
    "axe-core": "^4.10.2",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.8"
  }
}
